{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npx playwright test*)",
      "Bash(npx tsc --noEmit)",
      "Bash(pnpm lint*)",
      "Bash(pnpm format*)",
      "Bash(pnpm test*)",
      "Bash(gh pr view*)",
      "Bash(gh pr list*)",
      "Bash(gh pr status*)",
      "Bash(gh pr checks*)",
      "Bash(gh pr diff*)",
      "Bash(gh issue view*)",
      "Bash(gh issue list*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git status*)",
      "Bash(git branch*)",
      "Bash(ls *)",
      "Bash(git add *)",
      "Bash(git checkout *)",
      "Bash(git merge *)",
      "Bash(git commit -m *)",
      "Bash(rm *)"
    ],
    "ask": ["Bash(git push *)"],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(rm -R *)",
      "Bash(rm -fr *)",
      "Bash(rm -fR *)",
      "Bash(rm --recursive *)",
      "Bash(*git add*.env.keys*)",
      "Read(.env.keys)",
      "Bash(*cat*.env.keys*)",
      "Bash(*less*.env.keys*)",
      "Bash(*head*.env.keys*)",
      "Bash(*tail*.env.keys*)",
      "Bash(*grep*.env.keys*)",
      "Bash(echo $*PASSWORD*)",
      "Bash(echo $*SECRET*)",
      "Bash(echo $*TOKEN*)",
      "Bash(echo $*PRIVATE*)",
      "Bash(printenv*PASSWORD*)",
      "Bash(printenv*SECRET*)",
      "Bash(printenv*TOKEN*)",
      "Bash(printenv*PRIVATE*)",
      "Bash(printenv)",
      "Bash(printenv *)",
      "Bash(env)",
      "Bash(env *)",
      "Bash(*env*|*)",
      "Bash(*env*> *)",
      "Bash(node -e*)",
      "Bash(node --eval*)",
      "Bash(python3 -c*)",
      "Bash(python -c*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "file_path=$(cat - | jq -r '.tool_input.file_path // empty'); if [ -n \"$file_path\" ] && echo \"$file_path\" | grep -qE '\\.(ts|js|json)$'; then pnpm exec prettier --write \"$file_path\" || true; fi",
            "timeout": 15000
          },
          {
            "type": "command",
            "command": "file_path=$(cat - | jq -r '.tool_input.file_path // empty'); if [ -n \"$file_path\" ] && echo \"$file_path\" | grep -qE '\\.(ts|js)$'; then pnpm exec eslint \"$file_path\" --fix --quiet 2>/dev/null || true; fi",
            "timeout": 15000
          }
        ]
      }
    ]
  }
}
