{
  "name": "hotel-planisphere-playwright-ts",
  "version": "1.0.0",
  "description": "Playwright + TypeScript E2E Testing Portfolio",
  "scripts": {
    "prepare": "husky",
    "test": "dotenvx run -- npx playwright test",
    "test:ui": "dotenvx run -- npx playwright test --ui",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "playwright",
    "e2e",
    "typescript",
    "qa"
  ],
  "author": "Bey9434",
  "license": "ISC",
  "packageManager": "pnpm@10.28.2",
  "volta": {
    "node": "22.21.1",
    "pnpm": "10.28.0"
  },
  "lint-staged": {
    "*.{ts,mts}": "eslint --fix",
    "**/*": "prettier --write --ignore-unknown"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@dotenvx/dotenvx": "^1.69.2",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-functional": "^9.0.5",
    "eslint-plugin-playwright": "^2.10.4",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^17.0.6",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.60.0"
  }
}
